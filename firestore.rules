rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isHost(roomData) {
      return isAuthenticated() && roomData.hostId == request.auth.uid;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Users can only create/update their own profile
      allow create, update: if isAuthenticated() && request.auth.uid == userId;
    }

    // Rooms Collection
    match /rooms/{roomId} {
      // Any authenticated user can read public rooms or if they know the code (which implies trying to read it directly)
      allow read: if isAuthenticated();
      
      // Any authenticated user can create a room (they become the host)
      allow create: if isAuthenticated() && request.resource.data.hostId == request.auth.uid;
      
      // Only the host can update the room settings/status
      allow update: if isHost(resource.data);
      
      // Only the host can delete the room
      allow delete: if isHost(resource.data);

      // Students Subcollection inside a Room
      match /students/{studentId} {
        // Any authenticated user in the room can read the student list
        allow read: if isAuthenticated();
        
        // A student can only write/update their own answer document
        allow write: if isAuthenticated() && request.auth.uid == studentId;
      }
    }
  }
}
